.metal-mania-regular {
  font-family: "Metal Mania", system-ui;
  font-weight: 400;
  font-style: normal;
}
@font-face {
  font-family: "Metal Mania";
  src:
    url("MetalMania-Regular.woff2") format("woff2"),
    url("MetalMania-Regular.woff") format("woff");
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: "Black Ops One";
  src:
    url("BlackOpsOne-Regular.woff2") format("woff2"),
    url("BlackOpsOne-Regular.woff") format("woff");
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}
